rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function reviewOwner() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    function reviewOwnerExisting() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function followCreateIsValid() {
      return isSignedIn()
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.followerId is string
        && request.resource.data.followeeId is string
        && request.resource.data.followerId != request.resource.data.followeeId
        && request.resource.data.keys().hasOnly([
          'followerId',
          'followeeId',
          'createdAt',
          'updatedAt',
        ]);
    }

    function followDeleteIsValid() {
      return isSignedIn() && resource.data.followerId == request.auth.uid;
    }

    function validShelfStatus(status) {
      return status in ['want_to_read', 'reading', 'completed'];
    }

    function validCurrentPercent(data) {
      return !('currentPercent' in data) ||
        (data.currentPercent is int && data.currentPercent >= 0 && data.currentPercent <= 100);
    }

    function userBookCreateIsValid() {
      return isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userId is string
        && request.resource.data.bookId is string
        && validShelfStatus(request.resource.data.status)
        && validCurrentPercent(request.resource.data)
        && request.resource.data.keys().hasOnly([
          'userId',
          'bookId',
          'status',
          'currentPercent',
          'progressUpdatedAt',
          'createdAt',
          'updatedAt',
        ]);
    }

    function userBookUpdateIsValid() {
      return isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.bookId == resource.data.bookId
        && validShelfStatus(request.resource.data.status)
        && validCurrentPercent(request.resource.data)
        && request.resource.data.keys().hasOnly([
          'userId',
          'bookId',
          'status',
          'currentPercent',
          'progressUpdatedAt',
          'createdAt',
          'updatedAt',
        ]);
    }

    function bookCreateIsValid(bookId) {
      return isSignedIn()
        && request.resource.data.bookId == bookId
        && request.resource.data.bookId is string
        && request.resource.data.title is string
        && request.resource.data.authors is list
        && request.resource.data.keys().hasOnly([
          'bookId',
          'title',
          'authors',
          'thumbnailUrl',
          'createdAt',
          'updatedAt',
        ]);
    }

    match /books/{bookId} {
      allow read: if true;
      allow create: if bookCreateIsValid(bookId);
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update, delete: if isOwner(userId);
    }

    match /userBooks/{id} {
      allow read: if true;
      allow create: if userBookCreateIsValid();
      allow update: if userBookUpdateIsValid();
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if reviewOwner();
      allow update, delete: if reviewOwnerExisting();
    }

    match /userFollows/{followId} {
      allow read: if true;
      allow create: if followCreateIsValid();
      allow update: if false;
      allow delete: if followDeleteIsValid();
    }
  }
}
